# 只填写域名，不要添加 https://。域名的 A 记录必须指向服务器公网 IP。
APP_DOMAIN=resume.example.com

ENVIRONMENT=production
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=app-replace-with-your-new-key
DIFY_CONCURRENCY=3
DIFY_TIMEOUT_SECONDS=120
TASK_TTL_SECONDS=7200

# 至少 12 个字符；不要与 Dify API Key 或其他账号密码相同。
APP_ACCESS_CODE=replace-with-a-long-access-code
# 至少 32 个随机字符，可执行：openssl rand -hex 32
SESSION_SECRET=replace-with-at-least-32-random-characters
SESSION_TTL_SECONDS=28800
SESSION_COOKIE_SECURE=true

PER_IP_DAILY_RESUME_LIMIT=10
GLOBAL_DAILY_RESUME_LIMIT=50
QUOTA_TIMEZONE=Asia/Shanghai
MAX_REQUEST_BYTES=4194304
TRUST_PROXY_HEADERS=true
