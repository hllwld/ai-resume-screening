SESSION_COOKIE_SECURE=false

PER_IP_DAILY_RESUME_LIMIT=10
GLOBAL_DAILY_RESUME_LIMIT=50
QUOTA_TIMEZONE=Asia/Shanghai
QUOTA_DB_PATH=
